# WhatsApp Business API Credentials
WHATSAPP_TOKEN=       # Required - for sending/receiving messages
WHATSAPP_PHONE_ID=    # Required - WhatsApp phone number ID
WHATSAPP_APP_SECRET=  # Required - for HMAC signature verification
VERIFY_TOKEN=         # Required - used for webhook verification

# Groq AI Credentials
GROQ_API_KEY=         # Required - for transcription & order extraction

# API Authentication (Required)
API_KEY=              # Required - protects dashboard API endpoints

# Database Configuration
DATABASE_URL=         # Optional - uses SQLite if not set

# Server Configuration
PORT=8080
